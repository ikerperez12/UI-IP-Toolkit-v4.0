{
  "name": "ui-ip-toolkit",
  "private": true,
  "version": "4.0.0",
  "description": "Standalone frontend design system and component library with zero dependencies.",
  "homepage": "https://ui-ip-toolkit.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikerperez12/UI-IP-Toolkit-v4.0.git"
  },
  "bugs": {
    "url": "https://github.com/ikerperez12/UI-IP-Toolkit-v4.0/issues"
  },
  "scripts": {
    "start": "npx http-server . -p 3333",
    "check": "npm run check:js && npm run check:vercel && npm run check:a11y-smoke",
    "check:js": "node --check assets/app.js",
    "check:vercel": "node -e \"JSON.parse(require('fs').readFileSync('vercel.json','utf8')); console.log('vercel.json ok')\"",
    "check:a11y-smoke": "node scripts/accessibility-smoke.mjs"
  },
  "keywords": [
    "ui-kit",
    "frontend",
    "components",
    "css",
    "standalone"
  ],
  "license": "MIT",
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
